# =========================
# App
# =========================
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/seatgo
JWT_SECRET=change_this_secret
CORS_ORIGIN=http://localhost:5173

# =========================
# OTP
# =========================
OTP_EXPIRES_MIN=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SEC=60

# =========================
# Email principal conseillé: Nodemailer / SMTP
# Exemple Gmail
# SMTP_SERVICE=gmail
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=SeatGo <youraddress@gmail.com>
#
# Exemple Brevo / Mailtrap / autre SMTP
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_login
# SMTP_PASS=your_smtp_password
# SMTP_FROM=SeatGo <noreply@yourdomain.com>
# =========================
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SeatGo <noreply@yourdomain.com>
MAIL_FROM=SeatGo <noreply@yourdomain.com>

# =========================
# SendGrid (optional fallback)
# =========================
SENDGRID_API_KEY=

# =========================
# Resend (optional fallback)
# =========================
RESEND_API_KEY=
RESEND_FROM=

# =========================
# Admin bootstrap (optional)
# =========================
ADMIN_EMAIL=admin@universite.tg
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Université
ADMIN_PHONE=
ADMIN_CARD_NUMBER=ADMIN-0001